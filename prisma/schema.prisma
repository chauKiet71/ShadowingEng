generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum LessonLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum HistoryStatus {
  LEARNING
  COMPLETED
}

enum PackageStatus {
  ACTIVE
  PAUSED
}

enum DurationUnit {
  DAY
  MONTH
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum PaymentEventStatus {
  RECEIVED
  COMPLETED
  REJECTED
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  password         String?
  fullName         String     @map("full_name")
  avatarUrl        String?    @map("avatar_url")
  role             UserRole   @default(USER)
  status           UserStatus @default(ACTIVE)
  xp               Int        @default(0)
  level            Int        @default(1)
  streakDays       Int        @default(0) @map("streak_days")
  isPremium        Boolean    @default(false) @map("is_premium")
  premiumExpiresAt DateTime?  @map("premium_expires_at")
  packageId        String?    @map("package_id")
  package          Package?   @relation(fields: [packageId], references: [id])
  chatMessagesUsed Int        @default(0) @map("chat_messages_used")
  googleId         String?    @unique @map("google_id")
  lastActivity     DateTime?  @map("last_activity")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  histories         UserLessonHistory[]
  favorites         UserFavorite[]
  categoryFavs      CategoryFavorite[]
  paymentOrders     PaymentOrder[]
  chatConversations ChatConversation[]

  @@map("users")
}

model PasswordReset {
  id         String   @id @default(uuid())
  email      String
  codeHash   String   @map("code_hash")
  resetToken String?  @unique @map("reset_token")
  expiresAt  DateTime @map("expires_at")
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_resets")
}

model Package {
  id            String        @id @default(uuid())
  name          String
  description   String?
  price         Int
  duration      String
  durationUnit  DurationUnit  @default(MONTH) @map("duration_unit")
  days          Int           @default(0)
  months        Int           @default(1)
  monthlyPrice  Int           @map("monthly_price")
  originalPrice Int?          @map("original_price")
  badge         String?
  sortOrder     Int           @default(0) @map("sort_order")
  icon          String        @default("crown")
  status        PackageStatus @default(ACTIVE)
  isVisible     Boolean       @default(true) @map("is_visible")
  benefits      Json?
  limits        Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  users         User[]
  paymentOrders PaymentOrder[]

  @@map("packages")
}

model PaymentOrder {
  id          String        @id @default(uuid())
  paymentCode String        @unique @map("payment_code")
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId   String        @map("package_id")
  package     Package       @relation(fields: [packageId], references: [id])
  amount      Int
  status      PaymentStatus @default(PENDING)
  paidAmount  Int?          @map("paid_amount")
  paidAt      DateTime?     @map("paid_at")
  expiresAt   DateTime      @map("expires_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  transactions PaymentTransaction[]

  @@index([userId, status])
  @@index([expiresAt])
  @@map("payment_orders")
}

model PaymentTransaction {
  id                 String             @id @default(uuid())
  sepayTransactionId String             @unique @map("sepay_transaction_id")
  orderId            String?            @map("order_id")
  order              PaymentOrder?      @relation(fields: [orderId], references: [id])
  status             PaymentEventStatus @default(RECEIVED)
  reason             String?
  payload            Json
  createdAt          DateTime           @default(now()) @map("created_at")
  processedAt        DateTime?          @map("processed_at")

  @@index([orderId])
  @@map("payment_transactions")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  icon        String
  iconColor   String   @map("icon_color")
  imageUrl    String?  @map("image_url")
  lessonCount Int      @default(0) @map("lesson_count")
  isPopular   Boolean  @default(false) @map("is_popular")
  createdAt   DateTime @default(now()) @map("created_at")

  lessons   Lesson[]
  favorites CategoryFavorite[]

  @@map("categories")
}

model Lesson {
  id           String      @id @default(uuid())
  title        String
  description  String?
  audioUrl     String?     @map("audio_url")
  videoUrl     String?     @map("video_url")
  thumbnailUrl String?     @map("thumbnail_url")
  duration     Int         @default(0)
  level        LessonLevel @default(INTERMEDIATE)
  topic        String?
  categoryId   String?     @map("category_id")
  category     Category?   @relation(fields: [categoryId], references: [id])
  isFeatured   Boolean     @default(false) @map("is_featured")
  isNew        Boolean     @default(false) @map("is_new")
  isHot        Boolean     @default(false) @map("is_hot")
  createdAt    DateTime    @default(now()) @map("created_at")

  transcripts Transcript[]
  histories   UserLessonHistory[]
  favorites   UserFavorite[]

  @@map("lessons")
}

model Transcript {
  id          String @id @default(uuid())
  lessonId    String @map("lesson_id")
  lesson      Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  orderIndex  Int    @map("order_index")
  englishText String @map("english_text")
  vietnamese  String
  startTime   Float  @map("start_time")
  endTime     Float  @map("end_time")

  @@map("transcripts")
}

model UserLessonHistory {
  id                 String        @id @default(uuid())
  userId             String        @map("user_id")
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId           String        @map("lesson_id")
  lesson             Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progressPercentage Int           @default(0) @map("progress_percentage")
  status             HistoryStatus @default(LEARNING)
  listenedSeconds    Int           @default(0) @map("listened_seconds")
  isFavorite         Boolean       @default(false) @map("is_favorite")
  lastListenedAt     DateTime      @default(now()) @map("last_listened_at")

  @@unique([userId, lessonId])
  @@map("user_lesson_history")
}

model UserFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String   @map("lesson_id")
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, lessonId])
  @@map("user_favorites")
}

model CategoryFavorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([userId, categoryId])
  @@map("category_favorites")
}

/// Trạng thái khóa bài học (lessonId khớp với id trong lessons.json)
model LessonAccess {
  lessonId  String   @id @map("lesson_id")
  isLocked  Boolean  @default(true) @map("is_locked")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lesson_access")
}

model ChatConversation {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     CefrLevel
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String          @id @default(uuid())
  conversationId String          @map("conversation_id")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatMessageRole
  content        String
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}
