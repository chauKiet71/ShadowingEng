# Neon PostgreSQL (free tier có thể "ngủ" — lần kết nối đầu có thể mất ~15s)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000

# Tự động tạo/cập nhật bảng & cột khi khởi động server (mặc định: bật)
AUTO_SYNC_DB=true

# SMTP (tùy chọn — nếu không cấu hình, mã OTP sẽ in ra console)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password-no-spaces"
SMTP_FROM="Shadowing ENGLISH <noreply@shadowing.com>"

# OpenAI — dùng cho Shadowing STT (Whisper) & align timestamp
OPENAI_API_KEY="sk-your-openai-api-key"

# ElevenLabs — TTS / clone giọng (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY="sk_your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="your-elevenlabs-voice-id"
# ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"

# Google OAuth — đăng nhập / đăng ký bằng Google
# Tạo tại: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# SePay / VietQR — nhận thanh toán chuyển khoản
SEPAY_BANK="ACB"
SEPAY_ACCOUNT_NUMBER="12897891"
SEPAY_ACCOUNT_HOLDER="LE CHAU KIET"
SEPAY_PAYMENT_PREFIX="SHD"

# Chọn một phương thức xác thực webhook:
# 1) HMAC-SHA256 (khuyến nghị)
SEPAY_WEBHOOK_SECRET="replace-with-a-long-random-secret"
# 2) API Key (chỉ dùng nếu không cấu hình SEPAY_WEBHOOK_SECRET)
# SEPAY_WEBHOOK_API_KEY="replace-with-a-long-random-api-key"





























































































































































































































































































































































































































































































































































































































































































































































































































































































































































