# Neon PostgreSQL (free tier có thể "ngủ" — lần kết nối đầu có thể mất ~15s)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000

# Tự động tạo/cập nhật bảng & cột khi khởi động server (mặc định: bật)
AUTO_SYNC_DB=true

# SMTP (tùy chọn — nếu không cấu hình, mã OTP sẽ in ra console)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password-no-spaces"
SMTP_FROM="Shadowing ENGLISH <noreply@shadowing.com>"

# OpenAI — dùng cho Shadowing STT (Whisper) & align timestamp
OPENAI_API_KEY="sk-your-openai-api-key"

# ElevenLabs — TTS / clone giọng (https://elevenlabs.io/app/settings/api-keys)
